{
  "name": "nodeadmin-app",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc && nodeadmin copy-views",
    "start": "npm run build && pm2 start dist/index.js --watch",
    "start:dev": "nodemon",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js",
    "migration:create": "nodeadmin make-migration",
    "migration:run": "ts-node ./node_modules/typeorm/cli.js migration:run -d ./src/config/ormconfig.ts",
    "migration:revert": "ts-node ./node_modules/typeorm/cli.js migration:revert -d ./src/config/ormconfig.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:api": "jest tests/api",
    "test:security": "jest tests/security",
    "test:smoke": "jest tests/smoke",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:bdd": "cucumber-js",
    "lint:conventions": "nodeadmin check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Aplikasi admin panel berbasis NodeAdmin (@flazhost-nodeadmin/core).",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@flazhost-nodeadmin/core": "^1.3",
    "ali-oss": "^6.20.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "connect-redis": "^6.1.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "express-validator": "^7.1.0",
    "helmet": "^8.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "multer": "^2.2.0",
    "mysql2": "^3.10.1",
    "named-routes": "^2.0.7",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.12.0",
    "redis": "^4.6.15",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.34.3",
    "ts-node": "^10.9.2",
    "tsyringe": "^4.10.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@flazhost-nodeadmin/cli": "^1.2",
    "@playwright/test": "^1.61.0",
    "@types/ali-oss": "^6.16.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/connect-redis": "^0.0.23",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/method-override": "^0.0.35",
    "@types/multer": "^1.4.11",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^20.14.4",
    "@types/nodemailer": "^7.0.12",
