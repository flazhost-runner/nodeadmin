    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.3",
    "rimraf": "^5.0.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.30",
    "typescript": "^5.4.5"
  }
}
