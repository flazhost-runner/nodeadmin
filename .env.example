APP_PORT=3000
APP_HOST="http://localhost"
APP_NAME="Node Admin"
# Mode aplikasi: full (UI web + REST API) | api (REST API saja). Default: full.
APP_MODE=full
NODE_ENV=development

# Supported DB_TYPE: mysql | mariadb | postgres | cockroachdb | sqlite | better-sqlite3 | mssql | oracle
# - SQLite: isi DB_DATABASE dengan path file (mis. ./database.sqlite); host/port/user/pass diabaikan.
# - Install driver sesuai DB_TYPE: mysql2 (mysql/mariadb), pg (postgres/cockroachdb),
#   sqlite3/better-sqlite3, mssql, oracledb. Default terpasang: mysql2 + pg.
DB_TYPE=better-sqlite3
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=./dev.sqlite
DB_SYNCHRONIZE=false
DB_LOGGING=true

MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SECURE=false

REDIS_URL="redis://127.0.0.1:6379"

# Storage (object storage untuk upload file)
# STORAGE_DRIVER: oss | s3
# - oss : Alibaba Cloud OSS; isi STORAGE_ENDPOINT, STORAGE_REGION diabaikan.
# - s3  : AWS S3 atau S3-compatible (MinIO, Cloudflare R2, Backblaze B2, dll).
#         AWS S3 murni: kosongkan STORAGE_ENDPOINT, isi STORAGE_REGION.
#         S3-compatible custom: isi STORAGE_ENDPOINT + STORAGE_REGION.
STORAGE_DRIVER=oss
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=oss-ap-southeast-5.aliyuncs.com
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_SSL=true

# WAJIB diisi di production (app gagal start bila kosong saat NODE_ENV=production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=1h

# Keamanan & performa (opsional — ada default)
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
SESSION_TTL_HOURS=6
DB_CONNECTION_LIMIT=10
DEFAULT_PAGE_SIZE=10