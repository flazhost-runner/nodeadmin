NODE_ENV=test
APP_PORT=3001
APP_HOST=http://localhost
APP_NAME="Node Admin Test"

# DB: sqlite in-memory (app dialect-agnostic)
DB_TYPE=better-sqlite3
DB_DATABASE=:memory:
DB_SYNCHRONIZE=true
DB_LOGGING=false

REDIS_URL=redis://127.0.0.1:6379

# Secret dummy (test tidak perlu yang nyata)
SESSION_SECRET=test-session-secret-0123456789abcdef
JWT_SECRET=test-jwt-secret-0123456789abcdef
JWT_EXPIRES_IN=1h

BCRYPT_ROUNDS=4
OTP_EXPIRY_MINUTES=10

# OSS dummy (di-mock di test)
OSS_ACCESS_ID=test
OSS_ACCESS_KEY=test
OSS_ENDPOINT=oss-test.aliyuncs.com
OSS_BUCKET=test-bucket
OSS_SSL=true

MAIL_HOST=localhost
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM_NAME="Test"
MAIL_FROM_ADDRESS=test@example.com
